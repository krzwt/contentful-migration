  "servicesOverviewContent": {
    "945953": {
      "type": "processFlow",
      "enabled": true,
      "collapsed": false,
      "level": 1,
      "fields": {
        "headingSection": "Our Methodology",
        "processFlow": {
          "945954": {
            "type": 109,
            "fields": {
              "heading": "Scope",
              "body": "BeyondTrust Professional Services will work with you to ensure your services engagement is designed to meet your specific use case needs.",
              "image": [
                545710
              ]
            }
          },
          "945955": {
            "type": 109,
            "fields": {
              "heading": "Train",
              "body": "BeyondTrust University training will equip you to understand, administer, and get the most value from your solutions.",
              "image": [
                545691
              ]
            }
          },
          "945956": {
            "type": 109,
            "fields": {
              "heading": "Kickoff",
              "body": "Your BeyondTrust Professional Services project team will meet with you and key stakeholders to confirm project scope and understand use cases.",
              "image": [
                545723
              ]
            }
          },
          "945957": {
            "type": 109,
            "fields": {
              "heading": "Implement",
              "body": "BeyondTrust Engineers or Architects will work to install, configure, and deploy your BeyondTrust solutions aligned to your criteria.",
              "image": [
                545689
              ]
            }
          },
          "945958": {
            "type": 109,
            "fields": {
              "heading": "Maintain",
              "body": "BeyondTrust Support is available via email, chat, phone, or the Customer Portal to assist you with any issues that arise after your project has completed.",
              "image": [
                545722
              ]
            }
          }
        }
      }
    },
